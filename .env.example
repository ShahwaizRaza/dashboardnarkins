# Environment Variables (Optional)
# Copy this to .env if you need to customize

# API Base URL (default: http://127.0.0.1:5000)
# VITE_API_URL=http://127.0.0.1:5000

# Auto-refresh interval in milliseconds (default: 60000 = 60 seconds)
# VITE_REFRESH_INTERVAL=60000

# Enable debug mode
# VITE_DEBUG=false
